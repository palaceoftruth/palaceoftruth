{
  "manifest_version": 3,
  "name": "Palace Capture",
  "description": "Save the current page, post, media URL, or selected text to Palace.",
  "version": "0.1.0",
  "action": {
    "default_title": "Save to Palace",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"]
}
