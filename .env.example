# Database (docker-compose sets this automatically; override for external DB)
DB_PASSWORD=change_me_secure_password
# Host-side backend development reads these from .env. Docker Compose overrides
# them with in-network service URLs for containerized backend/worker services.
DATABASE_URL=postgresql+asyncpg://palaceoftruth:change_me_secure_password@localhost:5432/palaceoftruth
REDIS_URL=redis://localhost:6379

# OpenAI (embeddings + transcription only)
OPENAI_API_KEY=sk-...

# OpenRouter (LLM — chat, summarization, tagging)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=minimax/minimax-m2.7
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-super-120b-a12b
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
GITHUB_PAT=
PALACEOFTRUTH_SYNC_SOURCE_CREDENTIAL_KEY=

# API Auth (generate a strong random key)
API_KEY=change_me_api_key
PALACEOFTRUTH_ADMIN_SECRET=change_me_admin_secret

# Optional remote MCP OAuth client_credentials auth. Register the client through
# /api/v1/admin/tenants/{tenant_id}/mcp-clients/register and store the one-time
# client_secret outside git.
PALACEOFTRUTH_MCP_CLIENT_KEY=codex-local
PALACEOFTRUTH_MCP_CLIENT_NAME=Palace local MCP
PALACEOFTRUTH_MCP_CLIENT_SCOPES=read,write
PALACEOFTRUTH_MCP_OAUTH_CLIENT_SECRET=
PALACEOFTRUTH_MCP_BEARER_TOKEN=
PALACEOFTRUTH_MCP_OAUTH_TOKEN_URL=

# Optional frontend dev override. Host-run Vite will auto-detect a healthy backend,
# but you can pin it here if you want a specific target.
VITE_API_PROXY_TARGET=https://api.palaceoftruth.test
# Optional local-only browser API-key override. Prefer leaving this unset so the
# Vite proxy injects API_KEY server-side instead of exposing the shared secret.
VITE_API_KEY=

# Optional tuning (these match the defaults in config.py — only set to override)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_PROFILE_NAME=openai-text-embedding-3-small-1536
EMBEDDING_EXPERIMENTAL_PROFILES_ENABLED=false
# Optional TEI-compatible local HTTP embedding provider. Keep OpenAI defaults
# unless you have a 1536-dimensional local server and fresh embeddings planned.
EMBEDDING_LOCAL_HTTP_URL=
EMBEDDING_LOCAL_HTTP_PATH=/embed
EMBEDDING_LOCAL_HTTP_API_KEY=
EMBEDDING_LOCAL_HTTP_TIMEOUT_SECONDS=30
EMBEDDING_LOCAL_HTTP_NORMALIZE=true
EMBEDDING_LOCAL_HTTP_TRUNCATE=true
WHISPER_MODEL=gpt-4o-transcribe-diarize
TRANSCRIPTION_PROVIDER=openai
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_BASE_URL=https://api.assemblyai.com
ASSEMBLYAI_SPEECH_MODEL=universal-2
ASSEMBLYAI_POLL_INTERVAL_SECONDS=2.0
MEDIA_DOWNLOAD_TIMEOUT_SECONDS=1500
MEDIA_FFMPEG_TIMEOUT_SECONDS=300
TRANSCRIPTION_MAX_CHUNK_SECONDS=600
TRANSCRIPTION_REQUEST_TIMEOUT_SECONDS=300
TRANSCRIPTION_TRANSIENT_RETRIES=2
TRANSCRIPTION_RETRY_BACKOFF_SECONDS=2.0
TRANSCRIPTION_MAX_PARALLEL_CHUNKS=2
CHUNK_SIZE=500
CHUNK_OVERLAP=50
SEARCH_LIMIT=10
UPLOAD_ARTIFACT_DIR=/tmp/palaceoftruth/upload-artifacts
APP_VERSION=local
RETRIEVAL_CAPTURE_ENABLED=false
RETRIEVAL_CAPTURE_PATH=/tmp/palaceoftruth/retrieval-capture.ndjson
# fingerprint stores no raw query text. redacted stores token lengths. raw is for explicit local debugging only.
RETRIEVAL_CAPTURE_QUERY_MODE=fingerprint
RETRIEVAL_CAPTURE_MAX_QUERY_CHARS=500
RETRIEVAL_SOURCE_RANKING_ENABLED=true
RETRIEVAL_RELATIONSHIP_EXPANSION_ENABLED=false
RETRIEVAL_RELATIONSHIP_MIN_CONFIDENCE=0.7
RETRIEVAL_RELATIONSHIP_FANOUT_LIMIT=3
RETRIEVAL_RELATIONSHIP_HOP_DECAY=0.72
RETRIEVAL_RELATIONSHIP_MAX_BONUS=0.05
RETRIEVAL_HINT_RANKING_ENABLED=false
RETRIEVAL_HINT_RANKING_MAX_BONUS=0.06
RETRIEVAL_HINT_REPORT_ENABLED=false
RETRIEVAL_HINT_REPORT_LIMIT=5
RETRIEVAL_HINT_RESCUE_ENABLED=false
RETRIEVAL_HINT_RESCUE_MIN_SCORE=0.8
RETRIEVAL_HINT_RESCUE_LIMIT=3
RETRIEVAL_SECOND_STAGE_RERANKER_ENABLED=false
RETRIEVAL_SECOND_STAGE_RERANKER_PROVIDER=
RETRIEVAL_SECOND_STAGE_RERANKER_CANDIDATE_LIMIT=20
RETRIEVAL_SECOND_STAGE_RERANKER_TIMEOUT_MS=150
RETRIEVAL_SECOND_STAGE_RERANKER_MAX_BONUS=0.08
PALACE_SYNC_HOST_PATH=./docs
PALACE_SYNC_ALLOWED_ROOTS=/mnt/palace-sync,/app
PALACE_REPO_CHECKOUT_ROOT=/tmp/palaceoftruth/repo-checkouts
PALACE_SYNC_WATCHER_ENABLED=false
PALACE_SYNC_WATCHER_PROBE_SECONDS=10
FEED_POLL_MIN_INTERVAL=300
FEED_MAX_FAILURES=5
SOURCE_SUBSCRIPTION_POLL_MIN_INTERVAL=900
SOURCE_SUBSCRIPTION_MAX_FAILURES=5
SOURCE_SUBSCRIPTION_MANUAL_SYNC_COOLDOWN_SECONDS=300
SOURCE_SUBSCRIPTION_STALE_QUEUED_MINUTES=60

# Optional no-JavaScript social post capture.
# X posts use public server-side metadata without credentials, preferring rich
# article/post JSON and falling back to publish.twitter.com oEmbed.
# Facebook public posts need a Meta app token with the oEmbed Read / Meta oEmbed Read feature.
FACEBOOK_OEMBED_ACCESS_TOKEN=
FACEBOOK_GRAPH_API_VERSION=v25.0

# Optional Firecrawl webpage scraping.
# local keeps the built-in trafilatura/Playwright path. firecrawl-cloud uses
# https://api.firecrawl.dev/v2 and requires FIRECRAWL_API_KEY. firecrawl-self-hosted
# uses FIRECRAWL_BASE_URL and may omit FIRECRAWL_API_KEY when the deployment is
# protected by private networking instead of bearer auth.
WEBPAGE_SCRAPER_PROVIDER=local
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2
FIRECRAWL_API_KEY=
FIRECRAWL_TIMEOUT_SECONDS=60
FIRECRAWL_ONLY_MAIN_CONTENT=true
